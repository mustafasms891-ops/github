<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>حراج العراق</title>

<style>
body{
font-family:Arial,sans-serif;
background:#f5f5f5;
margin:0;
}

header{
background:#0d6efd;
color:white;
text-align:center;
padding:20px;
}

.container{
max-width:1000px;
margin:20px auto;
padding:10px;
}

.nav{
text-align:center;
margin:15px;
}

.nav a{
background:#0d6efd;
color:white;
padding:10px 15px;
text-decoration:none;
border-radius:5px;
margin:5px;
display:inline-block;
}

.ad{
background:white;
padding:15px;
margin:10px 0;
border-radius:10px;
box-shadow:0 0 8px rgba(0,0,0,.1);
}

.ad h3{
margin:0;
color:#0d6efd;
}

footer{
background:#222;
color:white;
text-align:center;
padding:20px;
margin-top:30px;
}
</style>

</head>

<body>

<header>
<h1>حراج العراق</h1>
<p>بيع وشراء بسهولة</p>
</header>

<div class="nav">
<a href="post.html">➕ نشر إعلان</a>
<button onclick="clearAds()">حذف كل الإعلانات</button>
</div>

<div class="container" id="adsBox">
</div>

<footer>
جميع الحقوق محفوظة © 2026 حراج العراق
</footer>

<script>

function loadAds(){
let ads = JSON.parse(localStorage.getItem("ads") || "[]");
let box = document.getElementById("adsBox");

box.innerHTML = "";

if(ads.length === 0){
box.innerHTML = "<p>لا توجد إعلانات حالياً</p>";
return;
}

ads.forEach(a => {
box.innerHTML += 
<div class="ad">
<h3>${a.title}</h3>
<p><b>التصنيف:</b> ${a.category}</p>
<p><b>السعر:</b> ${a.price}</p>
<p>${a.desc}</p>
</div>
;
});
}

function clearAds(){
localStorage.removeItem("ads");
loadAds();
}

loadAds();

</script>

</body>
</html>
